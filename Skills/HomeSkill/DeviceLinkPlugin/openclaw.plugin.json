{
  "id": "device-link",
  "name": "Device Link and Control Plugin",
  "version": "2.0.0",
  "entry": "index.js",
  "description": "Handles device connection, ECDH pairing, encryption, control, and status reporting",
  "type": "service",
  "tools": [
    "device.control",
    "device.pairing.start",
    "device.pairing.confirm",
    "device.pairing.reject",
    "device.reconnect",
    "device.unauthorize",
    "device.delete",
    "device.sync",
    "device.list"
  ],
  "services": [
    "device-listener",
    "mdns-discovery",
    "file-watcher"
  ],
  "dependencies": {
    "skills": ["home-smart-skill"],
    "npm": ["chokidar@^3.5.3"]
  }
}
